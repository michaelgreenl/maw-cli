{
    "name": "maw-cli",
    "version": "0.0.1",
    "description": "CLI for scaffolding and running MAW workflows.",
    "packageManager": "bun@1.3.9",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "maw-cli": "./bin/maw-cli.js"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "bin",
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@tsconfig/recommended": "^1.0.13",
        "@types/node": "^24.4.0",
        "eslint": "^9.39.1",
        "globals": "^16.5.0",
        "prettier": "^3.8.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.1",
        "vitest": "^3.2.4"
    }
}
