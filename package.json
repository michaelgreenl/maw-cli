{
  "name": "maw",
  "version": "0.0.1",
  "description": "CLI for scaffolding and running MAW workflows.",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "maw": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepare": "bun run build"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^24.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
